<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>History | People's Republic of Bulgaria</title>
  <meta name="description" content="Timeline of the People's Republic of Bulgaria, from 1944 to 1990." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Roboto:wght@300;400;700&display=swap" rel="stylesheet" />
  <link rel="icon" href="favicon.ico" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 62.5%; }
    body { font-family: 'Roboto', sans-serif; font-size: 1.6rem; background: #1a1a1a; color: #f0ebe0; }
    a { text-decoration: none; color: inherit; }
    ul { list-style: none; }
    img { display: block; max-width: 100%; }

    /* TOPBAR */
    .topbar { background: #111; border-bottom: 1px solid #333; padding: 8px 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
    .topbar-social { display: flex; gap: 14px; align-items: center; }
    .topbar-social img { height: 20px; width: auto; opacity: 0.75; }
    .topbar-social a:hover img { opacity: 1; }
    .topbar-lang { display: flex; gap: 8px; align-items: center; }
    .topbar-lang a img { height: 18px; width: 26px; object-fit: cover; border-radius: 2px; border: 2px solid transparent; opacity: 0.6; }
    .topbar-lang a:hover img, .topbar-lang a.active img { opacity: 1; border-color: #D62612; }

    /* HEADER */
    .site-header {
      position: relative;
      text-align: center;
      padding: 60px 20px 50px;
      background: url('/home/History.jpg') center 30%/cover no-repeat;
      min-height: 240px;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
    }
    .site-header::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at center, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.88) 100%);
    }
    .site-header img.logo { position: relative; height: 80px; margin: 0 auto 12px; }
    .site-header h1 { position: relative; font-family: 'Oswald', sans-serif; font-size: 3.2rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #f0ebe0; margin-bottom: 4px; }
    .site-header .tagline { position: relative; font-size: 1.3rem; color: #ccc; font-style: italic; }

    /* NAV */
    nav { background: #D62612; }
    nav ul {display: flex;flex-wrap: wrap;justify-content: center;}
    nav ul li a { display: block; padding: 12px 22px; font-family: 'Oswald', sans-serif; font-size: 1.5rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: #fff; }
    nav ul li a:hover { background: rgba(0,0,0,0.2); }
    nav ul li a.active { background: rgba(0,0,0,0.3); }

    /* PAGE */
    .page-wrap { max-width: 1000px; margin: 0 auto; padding: 30px 20px; }
    .page-title { font-family: 'Oswald', sans-serif; font-size: 2.8rem; font-weight: 700; text-transform: uppercase; color: #f0ebe0; border-bottom: 3px solid #D62612; padding-bottom: 10px; margin-bottom: 8px; }
    .page-subtitle { font-size: 1.45rem; color: #888; margin-bottom: 10px; line-height: 1.6; font-style: italic; }
    .notice-box { background: #242424; border-left: 4px solid #D62612; padding: 14px 18px; margin-bottom: 34px; font-size: 1.35rem; color: #888; font-style: italic; line-height: 1.7; }

    /* TIMELINE */
    .timeline { position: relative; padding-left: 0; }

    /* Red vertical line */
    .timeline::before {
      content: '';
      position: absolute;
      left: 110px;
      top: 0; bottom: 0;
      width: 3px;
      background: #D62612;
    }

    .timeline-item {
      display: flex;
      gap: 0;
      margin-bottom: 0;
      position: relative;
    }

    /* DATE column */
    .tl-date {
      width: 110px;
      flex-shrink: 0;
      padding: 22px 16px 22px 0;
      text-align: right;
    }
    .tl-date span {
      font-family: 'Oswald', sans-serif;
      font-size: 1.45rem;
      font-weight: 700;
      color: #D62612;
      line-height: 1.2;
      display: block;
    }

    /* DOT on the line */
    .tl-dot {
      width: 20px;
      flex-shrink: 0;
      display: flex;
      align-items: flex-start;
      padding-top: 28px;
      position: relative;
      z-index: 1;
    }
    .tl-dot::before {
      content: '';
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: #D62612;
      border: 3px solid #1a1a1a;
      margin-left: 3px;
      flex-shrink: 0;
    }

    /* CONTENT */
    .tl-content {
      flex: 1;
      padding: 18px 0 18px 22px;
      border-bottom: 1px solid #2a2a2a;
    }
    .timeline-item:last-child .tl-content { border-bottom: none; }

    .tl-content-inner {
      display: flex;
      gap: 18px;
      align-items: flex-start;
    }
    .tl-img {
      width: 120px;
      flex-shrink: 0;
      border: 1px solid #333;
    }
    .tl-img img { width: 100%; height: 90px; object-fit: cover; display: block; }
    .tl-text h3 {
      font-family: 'Oswald', sans-serif;
      font-size: 1.8rem; font-weight: 700;
      color: #f0ebe0;
      margin-bottom: 6px;
    }
    .tl-text p { font-size: 1.4rem; color: #aaa; line-height: 1.75; }

    /* FOOTER */
    footer { background: #111; border-top: 3px solid #D62612; padding: 24px 20px; text-align: center; margin-top: 20px; }
    .footer-nav { display: flex; justify-content: center; gap: 24px; flex-wrap: wrap; margin-bottom: 14px; }
    .footer-nav a { font-size: 1.4rem; color: #888; }
    .footer-nav a:hover { color: #D62612; text-decoration: underline; }
    .footer-social { display: flex; justify-content: center; gap: 16px; margin-bottom: 14px; }
    .footer-social img { height: 22px; width: auto; opacity: 0.6; }
    footer p { font-size: 1.25rem; color: #555; }

    @media (max-width: 680px) {
      .timeline::before { left: 0; }
      .tl-date { width: auto; padding: 16px 0 0; text-align: left; }
      .tl-dot { display: none; }
      .timeline-item { flex-direction: column; padding-left: 14px; border-left: 3px solid #D62612; margin-bottom: 20px; }
      .tl-content { padding: 8px 0 0; border-bottom: none; }
      .tl-content-inner { flex-direction: column; }
      .tl-img { width: 100%; }
      .tl-img img { height: 160px; }
      nav ul li a { padding: 10px 14px; font-size: 1.3rem; }
    }
  </style>
</head>
<body>

