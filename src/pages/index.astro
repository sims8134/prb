<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>People's Republic of Bulgaria — History, Collection & Cold War Bulgaria</title>
    <meta name="description" content="The first multilingual website dedicated to the history of the People's Republic of Bulgaria (1944–1990). Explore history, militaria, urbex, and Cold War Bulgaria." />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="People's Republic of Bulgaria — History, Collection & Cold War Bulgaria" />
    <meta property="og:description" content="The first multilingual website dedicated to the history of the People's Republic of Bulgaria (1944–1990). Explore history, militaria, urbex, and Cold War Bulgaria." />
    <meta property="og:image" content="https://peoplesrepublicofbulgaria.com/home/og.png" />
    <meta property="og:url" content="https://peoplesrepublicofbulgaria.com" />
    <meta property="og:site_name" content="People's Republic of Bulgaria" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="People's Republic of Bulgaria — History, Collection & Cold War Bulgaria" />
    <meta name="twitter:description" content="The first multilingual website dedicated to the history of the People's Republic of Bulgaria (1944–1990)." />
    <meta name="twitter:image" content="https://peoplesrepublicofbulgaria.com/home/og.png" />

    <link rel="icon" href="/favicon.ico" />

    <script>
      (() => {
        const supported = ["en", "fr", "es", "bg"];
        const stored = localStorage.getItem("site_lang");

        if (stored && supported.includes(stored)) {
          window.location.replace(`/${stored}/`);
          return;
        }

        const browserLang = (navigator.language || navigator.userLanguage || "en")
          .toLowerCase()
          .slice(0, 2);

        const target = supported.includes(browserLang) ? browserLang : "en";
        localStorage.setItem("site_lang", target);
        window.location.replace(`/${target}/`);
      })();
    </script>
  </head>
  <body></body>
</html>