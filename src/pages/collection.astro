      <p>📄 Download the full collection catalogue (PDF)</p>
      <a href="[Collection Catalog] Peoples Republic Of Bulgaria 2023 - 2024.pdf" target="_blank" rel="noopener noreferrer" class="btn-red">Download Catalogue</a>
    </div>

    <!-- Photo grid -->
    <p class="section-label">Photo Gallery</p>
    <div class="photo-grid" id="photoGrid">
      <div class="photo-item" onclick="openLightbox(0)"><img src="collection/Diaporama/diaporama/20221221_193920.jpg" alt="Collection 1" /></div>
      <div class="photo-item" onclick="openLightbox(1)"><img src="collection/Diaporama/diaporama/20230103_200009.jpg" alt="Collection 2" /></div>
      <div class="photo-item" onclick="openLightbox(2)"><img src="collection/Diaporama/diaporama/20230328_140524.jpg" alt="Collection 3" /></div>
      <div class="photo-item" onclick="openLightbox(3)"><img src="collection/Diaporama/diaporama/20231027_200838.jpg" alt="Collection 4" /></div>
      <div class="photo-item" onclick="openLightbox(4)"><img src="collection/Diaporama/diaporama/20231027_201308.jpg" alt="Collection 5" /></div>
      <div class="photo-item" onclick="openLightbox(5)"><img src="collection/Diaporama/diaporama/20231027_205843.jpg" alt="Collection 6" /></div>
      <div class="photo-item" onclick="openLightbox(6)"><img src="collection/Diaporama/diaporama/20231027_210303.jpg" alt="Collection 7" /></div>
      <div class="photo-item" onclick="openLightbox(7)"><img src="collection/Diaporama/diaporama/20231101_182648.jpg" alt="Collection 8" /></div>
      <div class="photo-item" onclick="openLightbox(8)"><img src="collection/Diaporama/diaporama/20231103_182119.jpg" alt="Collection 9" /></div>
      <div class="photo-item" onclick="openLightbox(9)"><img src="collection/Diaporama/diaporama/20231109_210242.jpg" alt="Collection 10" /></div>
      <div class="photo-item" onclick="openLightbox(10)"><img src="collection/Diaporama/diaporama/20231111_171916.jpg" alt="Collection 11" /></div>
      <div class="photo-item" onclick="openLightbox(11)"><img src="collection/Diaporama/diaporama/IMG_20230501_144838_952.jpg" alt="Collection 12" /></div>
