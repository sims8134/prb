  </div>

  <!-- LIGHTBOX -->
  <div class="lightbox" id="lightbox" onclick="closeLightboxOutside(event)">
    <span class="lightbox-close" onclick="closeLightbox()">✕</span>
    <span class="lightbox-prev" onclick="event.stopPropagation(); moveLight(-1)">&#8249;</span>
    <img class="lightbox-img" id="lightboxImg" src="" alt="" />
    <span class="lightbox-next" onclick="event.stopPropagation(); moveLight(1)">&#8250;</span>
    <span class="lightbox-counter" id="lightboxCounter"></span>
  </div>

  <!-- FOOTER -->
  <footer>
    <div class="footer-social">
      <a href="https://www.facebook.com/PeoplesRepublicOfBulgaria/" target="_blank" rel="noopener noreferrer"><img src="png/facebook.png" alt="Facebook" /></a>
      <a href="https://www.instagram.com/peoplesrepublicofbulgaria/" target="_blank" rel="noopener noreferrer"><img src="png/instagram.webp" alt="Instagram" /></a>
