<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Collection | People's Republic of Bulgaria</title>
  <meta name="description" content="Collection of objects from the People's Republic of Bulgaria — medals, uniforms, badges, documents and more." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Roboto:wght@300;400;700&display=swap" rel="stylesheet" />
  <link rel="icon" href="favicon.ico" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 62.5%; }
    body { font-family: 'Roboto', sans-serif; font-size: 1.6rem; background: #1a1a1a; color: #f0ebe0; }
    a { text-decoration: none; color: inherit; }
    ul { list-style: none; }
    img { display: block; max-width: 100%; }

    /* TOPBAR */
    .topbar { background: #111; border-bottom: 1px solid #333; padding: 8px 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
    .topbar-social { display: flex; gap: 14px; align-items: center; }
    .topbar-social img { height: 20px; width: auto; opacity: 0.75; }
    .topbar-social a:hover img { opacity: 1; }
    .topbar-lang { display: flex; gap: 8px; align-items: center; }
    .topbar-lang a img { height: 18px; width: 26px; object-fit: cover; border-radius: 2px; border: 2px solid transparent; opacity: 0.6; }
    .topbar-lang a:hover img, .topbar-lang a.active img { opacity: 1; border-color: #D62612; }

    /* HEADER */
    .site-header {
      position: relative;
      text-align: center;
      padding: 60px 20px 50px;
      background: url('/home/Collection.jpg') center 40%/cover no-repeat;
      min-height: 240px;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
    }
    .site-header::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at center, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.88) 100%);
    }
    .site-header img.logo { position: relative; height: 80px; margin: 0 auto 12px; }
    .site-header h1 { position: relative; font-family: 'Oswald', sans-serif; font-size: 3.2rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #f0ebe0; margin-bottom: 4px; }
    .site-header .tagline { position: relative; font-size: 1.3rem; color: #ccc; font-style: italic; }

    /* NAV */
    nav { background: #D62612; }
    nav ul {display: flex;flex-wrap: wrap;justify-content: center;}
    nav ul li a { display: block; padding: 12px 22px; font-family: 'Oswald', sans-serif; font-size: 1.5rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: #fff; }
    nav ul li a:hover { background: rgba(0,0,0,0.2); }
    nav ul li a.active { background: rgba(0,0,0,0.3); }

    /* PAGE */
    .page-wrap { max-width: 1100px; margin: 0 auto; padding: 30px 20px; }
    .page-title { font-family: 'Oswald', sans-serif; font-size: 2.8rem; font-weight: 700; text-transform: uppercase; color: #f0ebe0; border-bottom: 3px solid #D62612; padding-bottom: 10px; margin-bottom: 8px; }
    .page-subtitle { font-size: 1.45rem; color: #888; margin-bottom: 10px; font-style: italic; }
    .notice-box { background: #242424; border-left: 4px solid #D62612; padding: 14px 18px; margin-bottom: 28px; font-size: 1.35rem; color: #888; font-style: italic; line-height: 1.7; }

    /* CATALOGUE LINK */
    .catalogue-box {
      background: #242424;
      border: 1px solid #333;
      padding: 16px 20px;
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
    }
    .catalogue-box p { font-size: 1.45rem; color: #aaa; }
    .btn-red { display: inline-block; padding: 9px 20px; background: #D62612; color: #fff; font-family: 'Oswald', sans-serif; font-size: 1.4rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }
    .btn-red:hover { background: #9B1B0C; }

    /* LIGHTBOX GRID */
    .section-label { font-family: 'Oswald', sans-serif; font-size: 1.7rem; font-weight: 700; text-transform: uppercase; color: #D62612; border-bottom: 2px solid #333; padding-bottom: 8px; margin-bottom: 18px; }

    .photo-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
      margin-bottom: 40px;
    }
    .photo-item {
      aspect-ratio: 1/1;
      overflow: hidden;
      background: #242424;
      border: 1px solid #2e2e2e;
      cursor: pointer;
    }
    .photo-item:hover { border-color: #D62612; }
    .photo-item img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.3s;
    }
    .photo-item:hover img { transform: scale(1.05); }

    /* LIGHTBOX */
    .lightbox {
      display: none;
      position: fixed; inset: 0; z-index: 1000;
      background: rgba(0,0,0,0.92);
      align-items: center; justify-content: center;
      padding: 20px;
    }
    .lightbox.open { display: flex; }
    .lightbox-img {
      max-width: 90vw;
      max-height: 88vh;
      object-fit: contain;
      border: 2px solid #333;
    }
    .lightbox-close {
      position: fixed; top: 16px; right: 20px;
      font-size: 3.2rem; color: #aaa; cursor: pointer;
      font-family: 'Oswald', sans-serif; font-weight: 400;
      line-height: 1;
    }
    .lightbox-close:hover { color: #fff; }
    .lightbox-prev, .lightbox-next {
      position: fixed; top: 50%; transform: translateY(-50%);
      font-size: 3rem; color: #aaa; cursor: pointer;
      font-family: 'Oswald', sans-serif;
      background: rgba(0,0,0,0.5);
      padding: 10px 18px;
      user-select: none;
    }
    .lightbox-prev:hover, .lightbox-next:hover { color: #fff; background: rgba(214,38,18,0.7); }
    .lightbox-prev { left: 10px; }
    .lightbox-next { right: 10px; }
    .lightbox-counter { position: fixed; bottom: 16px; left: 50%; transform: translateX(-50%); font-size: 1.4rem; color: #666; font-family: 'Oswald', sans-serif; }

    /* FOOTER */
    footer { background: #111; border-top: 3px solid #D62612; padding: 24px 20px; text-align: center; margin-top: 10px; }
    .footer-nav { display: flex; justify-content: center; gap: 24px; flex-wrap: wrap; margin-bottom: 14px; }
    .footer-nav a { font-size: 1.4rem; color: #888; }
    .footer-nav a:hover { color: #D62612; text-decoration: underline; }
    .footer-social { display: flex; justify-content: center; gap: 16px; margin-bottom: 14px; }
    .footer-social img { height: 22px; width: auto; opacity: 0.6; }
    footer p { font-size: 1.25rem; color: #555; }

    @media (max-width: 800px) { .photo-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 560px) { .photo-grid { grid-template-columns: repeat(2, 1fr); } nav ul li a { padding: 10px 14px; font-size: 1.3rem; } }
  </style>
</head>
<body>

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="topbar-social">
      <a href="https://www.facebook.com/PeoplesRepublicOfBulgaria/" target="_blank" rel="noopener noreferrer"><img src="png/facebook.png" alt="Facebook" /></a>
      <a href="https://www.instagram.com/peoplesrepublicofbulgaria/" target="_blank" rel="noopener noreferrer"><img src="png/instagram.webp" alt="Instagram" /></a>
      <a href="https://www.youtube.com/@PeoplesRepublicOfBulgaria1505" target="_blank" rel="noopener noreferrer"><img src="png/Youtube_logo.png" alt="YouTube" /></a>
    </div>
    <div class="topbar-lang">
      <a href="collection.html" class="active"><img src="png/ukFlag.png" alt="EN" /></a>
      <a href="collection-fr.html"><img src="png/franceFlag.png" alt="FR" /></a>
      <a href="collection-es.html"><img src="png/spainFlag.png" alt="ES" /></a>
      <a href="collection-bg.html"><img src="png/bulgariaFlag.png" alt="BG" /></a>
    </div>
  </div>

  <!-- HEADER -->
  <div class="site-header">
    <img class="logo" src="png/PRB_logo.png" alt="People's Republic Of Bulgaria" onerror="this.style.display='none'" />
    <h1>People's Republic Of Bulgaria</h1>
    <p class="tagline">1944 — 1990 &nbsp;|&nbsp; Cultural &amp; Historical Archive</p>
  </div>

  <!-- NAV -->
  <nav>
    <ul>
      <li><a href="index.html">Home</a></li>
      <li><a href="history.html">History</a></li>
      <li><a href="collection.html" class="active">Collection</a></li>
      <li><a href="tourism.html">Tourism</a></li>
      <li><a href="video.html">video</a></li>
      
    </ul>
  </nav>

  <!-- CONTENT -->
  <div class="page-wrap">

    <h1 class="page-title">Collection</h1>
