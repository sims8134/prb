---
import MainLayout from "../../layouts/MainLayout.astro";
import {
  supportedLangs,
  siteContent,
  getLangFromParams,
  buildNav,
  buildFooter,
} from "../../data/site";

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromParams(Astro.params.lang);
const t = siteContent[lang];

const images = [
  "/tourism/diapo/20211106_135546.jpg",
  "/tourism/diapo/20211106_140338.jpg",
  "/tourism/diapo/20211106_141153.jpg",
  "/tourism/diapo/20220430_190649.jpg",
  "/tourism/diapo/20220501_165608.jpg",
  "/tourism/diapo/20220529_142138.jpg",
  "/tourism/diapo/20220813_140057.jpg",
  "/tourism/diapo/20230430_115759.jpg",
  "/tourism/diapo/20230506_112944.jpg",
  "/tourism/diapo/20230617_131501.jpg",
  "/tourism/diapo/20230820_144845.jpg",
  "/tourism/diapo/IMG_6325 (2).JPG",
];

const copy = {
  en: {
    title: "Tourism",
    subtitle: "Voyage, voyage...",
    contactText:
      "🗺️ If you wish to plan a private visit or if you need a guide, feel free to contact me:",
    gallery: "Photo Gallery",
    bottom1: "Planning a visit to Bulgaria? Need a private guide?",
  },
  fr: {
    title: "Tourisme",
    subtitle: "Voyage, voyage...",
    contactText:
      "🗺️ Si vous souhaitez organiser une visite privée ou si vous avez besoin d’un guide, n’hésitez pas à me contacter :",
    gallery: "Galerie photo",
    bottom1: "Vous préparez une visite en Bulgarie ? Besoin d’un guide privé ?",
  },
  es: {
    title: "Turismo",
    subtitle: "Voyage, voyage...",
    contactText:
      "🗺️ Si deseas organizar una visita privada o si necesitas un guía, no dudes en contactarme:",
    gallery: "Galería de fotos",
    bottom1: "¿Planeas una visita a Bulgaria? ¿Necesitas un guía privado?",
  },
  bg: {
    title: "Туризъм",
    subtitle: "Voyage, voyage...",
    contactText:
      "🗺️ Ако желаете да организирате частно посещение или имате нужда от гид, не се колебайте да се свържете с мен:",
    gallery: "Фотогалерия",
    bottom1: "Планирате посещение в България? Нуждаете се от частен гид?",
  },
}[lang];
---

<MainLayout
  lang={lang}
  title={t.tourism.title}
  description={t.tourism.description}
  nav={buildNav(lang, t)}
  footer={buildFooter(lang, t)}
  active="tourism"
  heroImage="/home/BackGroundHome.jpg"
>

<style>
.page-wrap {
  max-width: 1100px;
  margin: 0 auto;
  padding: 30px 20px;
}

.page-title {
  font-family: 'Oswald', sans-serif;
  font-size: 2.8rem;
  font-weight: 700;
  text-transform: uppercase;
  color: #f0ebe0;
  border-bottom: 3px solid #D62612;
  padding-bottom: 10px;
  margin-bottom: 8px;
}

.page-subtitle {
  font-size: 1.45rem;
  color: #888;
  margin-bottom: 20px;
  font-style: italic;
}

.contact-box {
  background: #242424;
  border: 1px solid #333;
  border-left: 4px solid #D62612;
  padding: 16px 20px;
  margin-bottom: 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
}

.contact-box p {
  font-size: 1.45rem;
  color: #aaa;
  line-height: 1.6;
}

.contact-box a.email {
  color: #D62612;
  font-weight: 700;
}

.contact-box a.email:hover {
  text-decoration: underline;
}

.section-label {
  font-family: 'Oswald', sans-serif;
  font-size: 1.7rem;
  font-weight: 700;
  text-transform: uppercase;
  color: #D62612;
  border-bottom: 2px solid #333;
  padding-bottom: 8px;
  margin-bottom: 18px;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 6px;
  margin-bottom: 30px;
}

.photo-item {
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #242424;
  border: 1px solid #2e2e2e;
  cursor: pointer;
}

.photo-item:hover {
  border-color: #D62612;
}

.photo-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s;
}

.photo-item:hover img {
  transform: scale(1.05);
}

.lightbox {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: rgba(0,0,0,0.92);
  align-items: center;
  justify-content: center;
  padding: 20px;
}

.lightbox.open {
  display: flex;
}

.lightbox-img {
  max-width: 90vw;
  max-height: 88vh;
  object-fit: contain;
  border: 2px solid #333;
}

.lightbox-close {
  position: fixed;
  top: 16px;
  right: 20px;
  font-size: 3.2rem;
  color: #aaa;
  cursor: pointer;
  font-family: 'Oswald', sans-serif;
  line-height: 1;
}

.lightbox-close:hover {
  color: #fff;
}

.lightbox-prev,
.lightbox-next {
  position: fixed;
  top: 50%;
  transform: translateY(-50%);
  font-size: 3rem;
  color: #aaa;
  cursor: pointer;
  background: rgba(0,0,0,0.5);
  padding: 10px 18px;
  user-select: none;
}

.lightbox-prev:hover,
.lightbox-next:hover {
  color: #fff;
  background: rgba(214,38,18,0.7);
}

.lightbox-prev { left: 10px; }
.lightbox-next { right: 10px; }

.lightbox-counter {
  position: fixed;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 1.4rem;
  color: #666;
  font-family: 'Oswald', sans-serif;
}

.bottom-contact {
  background: #D62612;
  padding: 20px 24px;
  text-align: center;
  margin-top: 10px;
}

.bottom-contact p {
  font-size: 1.5rem;
  color: rgba(255,255,255,0.9);
  margin-bottom: 8px;
}

.bottom-contact a {
  color: #fff;
  font-weight: 700;
  font-size: 1.6rem;
}

.bottom-contact a:hover {
  text-decoration: underline;
}

@media (max-width: 800px) {
  .photo-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 560px) {
  .photo-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>

<div class="page-wrap">
  <h1 class="page-title">{copy.title}</h1>
  <p class="page-subtitle">{copy.subtitle}</p>

  <div class="contact-box">
    <p>{copy.contactText}</p>
    <a href="mailto:contact@peoplesrepublicofbulgaria.com" class="email">
      contact@peoplesrepublicofbulgaria.com
    </a>
  </div>

  <p class="section-label">{copy.gallery}</p>

  <div class="photo-grid">
    {images.map((src, index) => (
      <div class="photo-item" data-index={index}>
        <img src={src} alt={`Tourism ${index + 1}`} />
      </div>
    ))}
  </div>
</div>

<div class="bottom-contact">
  <p>{copy.bottom1}</p>
  <a href="mailto:contact@peoplesrepublicofbulgaria.com">
    contact@peoplesrepublicofbulgaria.com
  </a>
</div>

<div class="lightbox" id="lightbox">
  <span class="lightbox-close" id="lightboxClose">✕</span>
  <span class="lightbox-prev" id="lightboxPrev">&#8249;</span>
  <img class="lightbox-img" id="lightboxImg" src="" alt="" />
  <span class="lightbox-next" id="lightboxNext">&#8250;</span>
  <span class="lightbox-counter" id="lightboxCounter"></span>
</div>

<script define:vars={{ images }}>
  let cur = 0;

  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightboxImg");
  const lightboxCounter = document.getElementById("lightboxCounter");
  const closeBtn = document.getElementById("lightboxClose");
  const prevBtn = document.getElementById("lightboxPrev");
  const nextBtn = document.getElementById("lightboxNext");
  const photoItems = document.querySelectorAll(".photo-item");

  function updateLightbox() {
    lightboxImg.src = images[cur];
    lightboxCounter.textContent = `${cur + 1} / ${images.length}`;
  }

  function openLightbox(index) {
    cur = index;
    updateLightbox();
    lightbox.classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function closeLightbox() {
    lightbox.classList.remove("open");
    document.body.style.overflow = "";
  }

  function moveLight(dir) {
    cur = (cur + dir + images.length) % images.length;
    updateLightbox();
  }

  photoItems.forEach((item, index) => {
    item.addEventListener("click", () => openLightbox(index));
  });

  closeBtn.addEventListener("click", closeLightbox);
  prevBtn.addEventListener("click", (e) => {
    e.stopPropagation();
    moveLight(-1);
  });
  nextBtn.addEventListener("click", (e) => {
    e.stopPropagation();
    moveLight(1);
  });

  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener("keydown", (e) => {
    if (!lightbox.classList.contains("open")) return;
    if (e.key === "ArrowRight") moveLight(1);
    if (e.key === "ArrowLeft") moveLight(-1);
    if (e.key === "Escape") closeLightbox();
  });
</script>

</MainLayout>
