---
import MainLayout from "../../layouts/MainLayout.astro";
import {
  supportedLangs,
  siteContent,
  getLangFromParams,
  buildNav,
  buildFooter,
} from "../../data/site";

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromParams(Astro.params.lang);
const t = siteContent[lang];

const images = [
  "/collection/Diaporama/diaporama/20221221_193920.jpg",
  "/collection/Diaporama/diaporama/20230103_200009.jpg",
  "/collection/Diaporama/diaporama/20230328_140524.jpg",
  "/collection/Diaporama/diaporama/20231027_200838.jpg",
  "/collection/Diaporama/diaporama/20231027_201308.jpg",
  "/collection/Diaporama/diaporama/20231027_205843.jpg",
  "/collection/Diaporama/diaporama/20231027_210303.jpg",
  "/collection/Diaporama/diaporama/20231101_182648.jpg",
  "/collection/Diaporama/diaporama/20231103_182119.jpg",
  "/collection/Diaporama/diaporama/20231109_210242.jpg",
  "/collection/Diaporama/diaporama/20231111_171916.jpg",
  "/collection/Diaporama/diaporama/IMG_20230501_144838_952.jpg",
];
---

<MainLayout
  lang={lang}
  title={t.collection.title}
  description={t.collection.description}
  nav={buildNav(lang, t)}
  footer={buildFooter(lang, t)}
  active="collection"
  heroImage="/home/BackGroundHome.jpg"
>

<style>
.page-wrap {
  max-width: 1100px;
  margin: 0 auto;
  padding: 30px 20px;
}

.page-title {
  font-family: 'Oswald', sans-serif;
  font-size: 2.8rem;
  font-weight: 700;
  text-transform: uppercase;
  color: #f0ebe0;
  border-bottom: 3px solid #D62612;
  padding-bottom: 10px;
  margin-bottom: 8px;
}

.page-subtitle {
  font-size: 1.45rem;
  color: #888;
  margin-bottom: 10px;
  font-style: italic;
}

.notice-box {
  background: #242424;
  border-left: 4px solid #D62612;
  padding: 14px 18px;
  margin-bottom: 28px;
  font-size: 1.35rem;
  color: #888;
  font-style: italic;
  line-height: 1.7;
}

.btn-red {
  display: inline-block;
  padding: 9px 20px;
  background: #D62612;
  color: #fff;
  font-family: 'Oswald', sans-serif;
  font-size: 1.4rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.btn-red:hover {
  background: #9B1B0C;
}

.section-label {
  font-family: 'Oswald', sans-serif;
  font-size: 1.7rem;
  font-weight: 700;
  text-transform: uppercase;
  color: #D62612;
  border-bottom: 2px solid #333;
  padding-bottom: 8px;
  margin-bottom: 18px;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 6px;
  margin-bottom: 40px;
}

.photo-item {
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #242424;
  border: 1px solid #2e2e2e;
  cursor: pointer;
}

.photo-item:hover {
  border-color: #D62612;
}

.photo-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s;
}

.photo-item:hover img {
  transform: scale(1.05);
}

.lightbox {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: rgba(0,0,0,0.92);
  align-items: center;
  justify-content: center;
  padding: 20px;
}

.lightbox.open {
  display: flex;
}

.lightbox-img {
  max-width: 90vw;
  max-height: 88vh;
  object-fit: contain;
  border: 2px solid #333;
}

.lightbox-close {
  position: fixed;
  top: 16px;
  right: 20px;
  font-size: 3.2rem;
  color: #aaa;
  cursor: pointer;
  font-family: 'Oswald', sans-serif;
  font-weight: 400;
  line-height: 1;
}

.lightbox-close:hover {
  color: #fff;
}

.lightbox-prev,
.lightbox-next {
  position: fixed;
  top: 50%;
  transform: translateY(-50%);
  font-size: 3rem;
  color: #aaa;
  cursor: pointer;
  font-family: 'Oswald', sans-serif;
  background: rgba(0,0,0,0.5);
  padding: 10px 18px;
  user-select: none;
}

.lightbox-prev:hover,
.lightbox-next:hover {
  color: #fff;
  background: rgba(214,38,18,0.7);
}

.lightbox-prev { left: 10px; }
.lightbox-next { right: 10px; }

.lightbox-counter {
  position: fixed;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 1.4rem;
  color: #666;
  font-family: 'Oswald', sans-serif;
}

@media (max-width: 800px) {
  .photo-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 560px) {
  .photo-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>

<div class="page-wrap">
  <h1 class="page-title">
    {
      lang === "fr" ? "Collection"
      : lang === "es" ? "Colección"
      : lang === "bg" ? "Колекция"
      : "Collection"
    }
  </h1>

  <p class="page-subtitle">
    {
      lang === "fr" ? "« Si les objets pouvaient parler... »"
      : lang === "es" ? "« Si los objetos pudieran hablar... »"
      : lang === "bg" ? "„Ако предметите можеха да говорят...“"
      : '"If objects could speak..."'
    }
  </p>

  <div class="notice-box">
    {
      lang === "fr"
        ? "Ce site a été créé à des fins culturelles et historiques uniquement. Il n’est en aucun cas l’outil d’une idéologie politique."
        : lang === "es"
        ? "Este sitio ha sido creado únicamente con fines culturales e históricos. No es en modo alguno una herramienta de ninguna ideología política."
        : lang === "bg"
        ? "Този сайт е създаден само с културна и историческа цел. По никакъв начин не е инструмент на политическа идеология."
        : "This website has been created for cultural and historical purposes only. It is in no way the tool of any political ideology."
    }
  </div>


  <p class="section-label">
    {
      lang === "fr" ? "Galerie photo"
      : lang === "es" ? "Galería de fotos"
      : lang === "bg" ? "Фотогалерия"
      : "Photo Gallery"
    }
  </p>

  <div class="photo-grid">
    {images.map((src, index) => (
      <div class="photo-item" data-index={index}>
        <img src={src} alt={`Collection ${index + 1}`} />
      </div>
    ))}
  </div>
</div>

<div class="lightbox" id="lightbox">
  <span class="lightbox-close" id="lightboxClose">✕</span>
  <span class="lightbox-prev" id="lightboxPrev">&#8249;</span>
  <img class="lightbox-img" id="lightboxImg" src="" alt="" />
  <span class="lightbox-next" id="lightboxNext">&#8250;</span>
  <span class="lightbox-counter" id="lightboxCounter"></span>
</div>

<script define:vars={{ images }}>
  let cur = 0;

  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightboxImg");
  const lightboxCounter = document.getElementById("lightboxCounter");
  const closeBtn = document.getElementById("lightboxClose");
  const prevBtn = document.getElementById("lightboxPrev");
  const nextBtn = document.getElementById("lightboxNext");
  const photoItems = document.querySelectorAll(".photo-item");

  function updateLightbox() {
    lightboxImg.src = images[cur];
    lightboxCounter.textContent = `${cur + 1} / ${images.length}`;
  }

  function openLightbox(index) {
    cur = index;
    updateLightbox();
    lightbox.classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function closeLightbox() {
    lightbox.classList.remove("open");
    document.body.style.overflow = "";
  }

  function moveLight(dir) {
    cur = (cur + dir + images.length) % images.length;
    updateLightbox();
  }

  photoItems.forEach((item, index) => {
    item.addEventListener("click", () => openLightbox(index));
  });

  closeBtn.addEventListener("click", closeLightbox);
  prevBtn.addEventListener("click", (e) => {
    e.stopPropagation();
    moveLight(-1);
  });
  nextBtn.addEventListener("click", (e) => {
    e.stopPropagation();
    moveLight(1);
  });

  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener("keydown", (e) => {
    if (!lightbox.classList.contains("open")) return;
    if (e.key === "ArrowRight") moveLight(1);
    if (e.key === "ArrowLeft") moveLight(-1);
    if (e.key === "Escape") closeLightbox();
  });
</script>

</MainLayout>
