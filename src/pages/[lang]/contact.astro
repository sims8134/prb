---
import MainLayout from "../../layouts/MainLayout.astro";
import {
  supportedLangs,
  siteContent,
  getLangFromParams,
  buildNav,
  buildFooter,
} from "../../data/site";

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromParams(Astro.params.lang);
const t = siteContent[lang];

const copy = {
  en: {
    title: "Contact",
    subtitle: "A question? A request? A suggestion? Don't hesitate to get in touch!",
    sendMessage: "Send a message",
    name: "Name",
    email: "Email",
    subject: "Subject",
    message: "Message",
    yourName: "Your name",
    yourEmail: "your@email.com",
    yourMessage: "Your message...",
    selectSubject: "— Select a subject —",
    s1: "Collection",
    s2: "Tourism / Private visit",
    s3: "Store",
    s4: "Partnership / Press",
    s5: "Other",
    send: "Send message",
    emailTitle: "Email",
    emailText: "For any question about the collection, tourism, the store or the website:",
    follow: "Follow us",
    igText: "Instagram — Photos, collection, urbex",
    ytText: "YouTube — videos, urbex, vlogs, edits",
    fbText: "Facebook Page",
    errFields: "⚠ Please fill in all fields.",
    errEmail: "⚠ Please enter a valid email address.",
    ok: "✓ Message sent successfully!",
  },
  fr: {
    title: "Contact",
    subtitle: "Une question ? Une demande ? Une suggestion ? N'hésitez pas à me contacter !",
    sendMessage: "Envoyer un message",
    name: "Nom",
    email: "Email",
    subject: "Sujet",
    message: "Message",
    yourName: "Votre nom",
    yourEmail: "votre@email.com",
    yourMessage: "Votre message...",
    selectSubject: "— Sélectionnez un sujet —",
    s1: "Collection",
    s2: "Tourisme / Visite privée",
    s3: "Boutique",
    s4: "Partenariat / Presse",
    s5: "Autre",
    send: "Envoyer le message",
    emailTitle: "Email",
    emailText: "Pour toute question concernant la collection, le tourisme, la boutique ou le site :",
    follow: "Suivez-nous",
    igText: "Instagram — Photos, collection, urbex",
    ytText: "YouTube — vidéos, urbex, vlogs, montages",
    fbText: "Page Facebook",
    errFields: "⚠ Veuillez remplir tous les champs.",
