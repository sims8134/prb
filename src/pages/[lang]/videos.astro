---
import MainLayout from "../../layouts/MainLayout.astro";
import {
  supportedLangs,
  siteContent,
  getLangFromParams,
  buildNav,
  buildFooter,
} from "../../data/site";
import { getPlaylistVideos } from "../../data/youtube";

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromParams(Astro.params.lang);
const t = siteContent[lang];

const copy = {
  en: {
    title: "Videos",
    subtitle: "All videos organised by category. Click a thumbnail to load it in the player.",
    subscribeTitle: "Subscribe to the Channel",
    subscribeText: "New videos regularly — don't miss anything about the People's Republic of Bulgaria.",
    subscribeBtn: "Subscribe on YouTube",
    more: "More videos from this category",
    watch: "Watch on YouTube",
    playlist: "Full Playlist",
    empty: "No videos found in this playlist yet.",
  },
  fr: {
    title: "Vidéos",
    subtitle: "Toutes les vidéos classées par catégorie. Cliquez sur une miniature pour la charger dans le lecteur.",
    subscribeTitle: "S’abonner à la chaîne",
    subscribeText: "De nouvelles vidéos régulièrement — ne manquez rien sur la République populaire de Bulgarie.",
    subscribeBtn: "S’abonner sur YouTube",
    more: "Plus de vidéos de cette catégorie",
    watch: "Voir sur YouTube",
    playlist: "Playlist complète",
    empty: "Aucune vidéo trouvée dans cette playlist pour le moment.",
  },
  es: {
    title: "Vídeos",
    subtitle: "Todos los vídeos organizados por categoría. Haz clic en una miniatura para cargarla en el reproductor.",
    subscribeTitle: "Suscribirse al canal",
    subscribeText: "Nuevos vídeos regularmente — no te pierdas nada sobre la República Popular de Bulgaria.",
    subscribeBtn: "Suscribirse en YouTube",
    watch: "Ver en YouTube",
    playlist: "Lista completa",
    more: "Más vídeos de esta categoría",
    empty: "Todavía no se han encontrado vídeos en esta lista.",
  },
  bg: {
    title: "Видеа",
    subtitle: "Всички видеа са организирани по категории. Натиснете върху миниатюра, за да я заредите в плеъра.",
    subscribeTitle: "Абонирай се за канала",
    subscribeText: "Нови видеа редовно — не пропускайте нищо за Народна република България.",
    subscribeBtn: "Абонирай се в YouTube",
    watch: "Гледай в YouTube",
    playlist: "Цял плейлист",
    more: "Още видеа от тази категория",
    empty: "Все още няма намерени видеа в този плейлист.",
  },
}[lang];

const playlistMap = [
  {
    key: "urbex",
    icon: "🏚️",
    playlistId: import.meta.env.PLAYLIST_URBEX,
    playlistLabel: "Urbex",
    title: {
      en: "Urbex — Abandoned Communist Bulgaria",
      fr: "Urbex — Bulgarie communiste abandonnée",
      es: "Urbex — Bulgaria comunista abandonada",
      bg: "Urbex — Изоставена комунистическа България",
    },
    text: {
      en: "Exploring forgotten buildings, military bases and ghost sites from the communist era.",
      fr: "Exploration de bâtiments oubliés, bases militaires et lieux fantômes de l’époque communiste.",
      es: "Exploración de edificios olvidados, bases militares y lugares fantasma de la era comunista.",
      bg: "Изследване на забравени сгради, военни бази и призрачни места от комунистическата епоха.",
    },
  },
  {
    key: "vlog",
    icon: "🎥",
    playlistId: import.meta.env.PLAYLIST_VLOG,
    playlistLabel: "Vlog",
    title: {
      en: "Vlog — Life in Sofia & Bulgarian Adventures",
      fr: "Vlog — Vie à Sofia et aventures en Bulgarie",
      es: "Vlog — Vida en Sofía y aventuras en Bulgaria",
      bg: "Влог — Живот в София и приключения в България",
    },
    text: {
      en: "Day-to-day life, markets, discoveries and adventures in Bulgaria.",
      fr: "Vie quotidienne, marchés, découvertes et aventures en Bulgarie.",
      es: "Vida cotidiana, mercados, descubrimientos y aventuras en Bulgaria.",
      bg: "Всекидневие, пазари, открития и приключения в България.",
    },
  },
  {
    key: "edit",
    icon: "🎬",
    playlistId: import.meta.env.PLAYLIST_EDIT,
    playlistLabel: "Edit",
    title: {
      en: "Edit — Cinematic Communist Bulgaria",
      fr: "Edit — Bulgarie communiste cinématique",
      es: "Edit — Bulgaria comunista cinematográfica",
      bg: "Edit — Кинематографична комунистическа България",
    },
    text: {
      en: "Atmospheric edits with archive footage, music and cold war atmosphere.",
      fr: "Montages d’ambiance avec archives, musique et atmosphère guerre froide.",
      es: "Edits atmosféricos con archivos, música y ambiente de Guerra Fría.",
      bg: "Атмосферни монтажи с архивни кадри, музика и дух на Студената война.",
    },
  },
  {
    key: "unboxing",
    icon: "📦",
    playlistId: import.meta.env.PLAYLIST_UNBOXING,
    playlistLabel: "Unboxing",
    title: {
      en: "Unboxing — Communist Era Objects",
      fr: "Unboxing — Objets de l’époque communiste",
      es: "Unboxing — Objetos de la era comunista",
      bg: "Unboxing — Предмети от комунистическата епоха",
    },
    text: {
      en: "Flea market finds, rare military items, propaganda objects — detailed unboxings of historical artefacts.",
      fr: "Trouvailles de brocante, objets militaires rares, propagande — déballages détaillés d’artefacts historiques.",
      es: "Hallazgos de mercadillo, objetos militares raros, propaganda — unboxings detallados de artefactos históricos.",
      bg: "Находки от битпазари, редки военни предмети, пропаганда — детайлни представяния на исторически артефакти.",
    },
  },
  {
    key: "presentation",
    icon: "🎖️",
    playlistId: import.meta.env.PLAYLIST_PRESENTATION,
    playlistLabel: "Presentation",
    title: {
      en: "Presentation — Detailed Object Reviews",
      fr: "Présentation — Objets en détail",
      es: "Presentación — Reseñas detalladas de objetos",
      bg: "Представяне — Подробни ревюта на предмети",
    },
    text: {
      en: "In-depth presentations of medals, uniforms, badges, documents — with historical context.",
      fr: "Présentations détaillées de médailles, uniformes, insignes, documents — avec contexte historique.",
      es: "Presentaciones detalladas de medallas, uniformes, insignias y documentos — con contexto histórico.",
      bg: "Подробни представяния на медали, униформи, значки и документи — с исторически контекст.",
    },
  },
  {
    key: "tourism",
    icon: "🗺️",
    playlistId: import.meta.env.PLAYLIST_TOURISM,
    playlistLabel: "Tourism",
    title: {
      en: "Tourism — Communist Heritage Sites",
      fr: "Tourisme — Sites patrimoniaux communistes",
      es: "Turismo — Lugares patrimoniales comunistas",
      bg: "Туризъм — Комунистически исторически обекти",
    },
    text: {
      en: "Guided visits to monuments, museums and communist-era sites across Bulgaria.",
      fr: "Visites guidées de monuments, musées et sites de l’époque communiste à travers la Bulgarie.",
      es: "Visitas guiadas a monumentos, museos y lugares de la época comunista en Bulgaria.",
      bg: "Обиколки на паметници, музеи и обекти от комунистическата епоха в България.",
    },
  },
];

const categories = await Promise.all(
  playlistMap.map(async (cat) => {
    const videos = cat.playlistId ? await getPlaylistVideos(cat.playlistId) : [];
    return {
      key: cat.key,
      icon: cat.icon,
      playlistId: cat.playlistId,
      playlistLabel: cat.playlistLabel,
      title: cat.title[lang],
      text: cat.text[lang],
      featured: videos[0] ?? null,
      videos,
    };
  })
);
---

<MainLayout
  lang={lang}
  title={t.videos.title}
  description={t.videos.description}
  nav={buildNav(lang, t)}
  footer={buildFooter(lang, t)}
  active="videos"
  heroImage="/home/BackGroundHome.jpg"
>

<style>
.page-wrap {
  max-width: 1100px;
  margin: 0 auto;
  padding: 30px 20px;
}

.page-title {
  font-family: 'Oswald', sans-serif;
  font-size: 2.8rem;
  font-weight: 700;
  text-transform: uppercase;
  color: #f0ebe0;
  border-bottom: 3px solid #D62612;
  padding-bottom: 10px;
  margin-bottom: 8px;
}

.page-subtitle {
  font-size: 1.45rem;
  color: #888;
  margin-bottom: 28px;
  line-height: 1.6;
}

.tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-bottom: 24px;
}

.tab-btn {
  padding: 9px 20px;
  background: #242424;
  border: 1px solid #333;
  color: #aaa;
  font-family: 'Oswald', sans-serif;
  font-size: 1.45rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  cursor: pointer;
}

.tab-btn:hover {
  background: #2e2e2e;
  color: #f0ebe0;
}

.tab-btn.active {
  background: #D62612;
  border-color: #D62612;
  color: #fff;
}

.tab-panel {
  display: none;
}

.tab-panel.active {
  display: block;
}

.player-box {
  background: #242424;
  border: 1px solid #333;
  padding: 16px;
  margin-bottom: 20px;
}

.player-embed {
  position: relative;
  padding-bottom: 56.25%;
  background: #000;
  margin-bottom: 14px;
}

.player-embed iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: 0;
}

.player-meta h3 {
  font-family: 'Oswald', sans-serif;
  font-size: 2rem;
  font-weight: 700;
  color: #f0ebe0;
  margin-bottom: 6px;
}

.player-meta p {
  font-size: 1.4rem;
  color: #888;
  line-height: 1.7;
  margin-bottom: 14px;
}

.player-links {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.btn-red {
  display: inline-block;
  padding: 8px 18px;
  background: #D62612;
  color: #fff;
  font-family: 'Oswald', sans-serif;
  font-size: 1.4rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.btn-red:hover {
  background: #9B1B0C;
}

.btn-outline {
  display: inline-block;
  padding: 8px 18px;
  background: transparent;
  color: #aaa;
  border: 1px solid #555;
  font-family: 'Oswald', sans-serif;
  font-size: 1.4rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.btn-outline:hover {
  color: #f0ebe0;
  border-color: #888;
}

.section-label {
  font-family: 'Oswald', sans-serif;
  font-size: 1.6rem;
  font-weight: 600;
  text-transform: uppercase;
  color: #888;
  border-bottom: 1px solid #333;
  padding-bottom: 6px;
  margin-bottom: 14px;
}

.thumb-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.thumb-card {
  background: #242424;
  border: 1px solid #333;
  cursor: pointer;
}

.thumb-card:hover {
  border-color: #D62612;
}

.thumb-img {
  position: relative;
  aspect-ratio: 16 / 9;
  background: #111;
  overflow: hidden;
}

.thumb-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.thumb-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 3.2rem;
}

.thumb-body {
  padding: 10px 12px;
}

.thumb-body h4 {
  font-family: 'Oswald', sans-serif;
  font-size: 1.5rem;
  color: #f0ebe0;
  margin-bottom: 3px;
}

.thumb-body p {
  font-size: 1.25rem;
  color: #666;
}

.empty-box {
  background: #242424;
  border: 1px solid #333;
  padding: 24px;
  color: #888;
  font-size: 1.5rem;
}

.subscribe-box {
  background: #D62612;
  padding: 24px;
  text-align: center;
  margin-top: 30px;
}

.subscribe-box h3 {
  font-family: 'Oswald', sans-serif;
  font-size: 2.2rem;
  font-weight: 700;
  text-transform: uppercase;
  color: #fff;
  margin-bottom: 8px;
}

.subscribe-box p {
  font-size: 1.4rem;
  color: rgba(255,255,255,0.8);
  margin-bottom: 16px;
}

.btn-white {
  display: inline-block;
  padding: 10px 26px;
  background: #fff;
  color: #D62612;
  font-family: 'Oswald', sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  text-transform: uppercase;
}

.btn-white:hover {
  background: #f0ebe0;
}

@media (max-width: 700px) {
  .thumb-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 480px) {
  .thumb-grid {
    grid-template-columns: 1fr;
  }

  .player-links {
    flex-direction: column;
  }
}
</style>

<div class="page-wrap">
  <h1 class="page-title">{copy.title}</h1>
  <p class="page-subtitle">{copy.subtitle}</p>

  <div class="tabs">
    {categories.map((cat, index) => (
      <button class={`tab-btn ${index === 0 ? "active" : ""}`} data-tab={cat.key}>
        {cat.icon} {cat.playlistLabel}
      </button>
    ))}
  </div>

  {categories.map((cat, index) => (
    <div class={`tab-panel ${index === 0 ? "active" : ""}`} id={`tab-${cat.key}`}>
      {cat.featured ? (
        <>
          <div class="player-box">
            <div class="player-embed">
              <iframe
                id={`iframe-${cat.key}`}
                src={`https://www.youtube.com/embed/${cat.featured.videoId}?rel=0`}
                title={cat.featured.title}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>

            <div class="player-meta">
              <h3>{cat.title}</h3>
              <p>{cat.text}</p>
              <div class="player-links">
                <a
                  href={`https://www.youtube.com/watch?v=${cat.featured.videoId}`}
                  target="_blank" rel="noopener noreferrer"
                  class="btn-red"
                >
                  ▶ {copy.watch}
                </a>
                <a
                  href={`https://www.youtube.com/playlist?list=${cat.playlistId}`}
                  target="_blank" rel="noopener noreferrer"
                  class="btn-outline"
                >
                  ☰ {copy.playlist}
                </a>
              </div>
            </div>
          </div>

          <p class="section-label">{copy.more}</p>

<div class="thumb-grid">
  {cat.videos.slice(1, 4).map((video) => (
    <div
      class="thumb-card"
      data-type="video"
      data-tab={cat.key}
      data-videoid={video.videoId}
    >
      <div class="thumb-img">
        <img src={video.thumbnail} alt={video.title} loading="lazy" />
      </div>
      <div class="thumb-body">
        <h4>{video.title}</h4>
        <p>
  {lang === "fr"
    ? "Voir cette vidéo →"
    : lang === "es"
    ? "Ver este vídeo →"
    : lang === "bg"
    ? "Гледай това видео →"
    : "Watch this video →"}
</p>
      </div>
    </div>
  ))}
</div>

            <div
              class="thumb-card"
              data-type="playlist"
              data-playlist={cat.playlistId}
            >
              <div class="thumb-img">
                <div class="thumb-placeholder">▶</div>
              </div>
              <div class="thumb-body">
                <h4>{cat.playlistLabel} Playlist</h4>
                <p>
                  {lang === "fr"
                    ? "Tout le contenu →"
                    : lang === "es"
                    ? "Todo el contenido →"
                    : lang === "bg"
                    ? "Цялото съдържание →"
                    : "All content →"}
                </p>
              </div>
            </div>
          </div>
        </>
      ) : (
        <div class="empty-box">{copy.empty}</div>
      )}
    </div>
  ))}

  <div class="subscribe-box">
    <h3>{copy.subscribeTitle}</h3>
    <p>{copy.subscribeText}</p>
    <a
      href="https://www.youtube.com/@PeoplesRepublicOfBulgaria1505"
      target="_blank" rel="noopener noreferrer"
      class="btn-white"
    >
      ▶ {copy.subscribeBtn}
    </a>
  </div>
</div>

<script>
  document.querySelectorAll('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach((p) => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tab-' + btn.dataset.tab)?.classList.add('active');
    });
  });

  function play(tab, videoId) {
    const iframe = document.getElementById('iframe-' + tab);
    if (!iframe) return;
    iframe.src = 'https://www.youtube.com/embed/' + videoId + '?autoplay=1&rel=0&modestbranding=1';
    document.getElementById('tab-' + tab)?.scrollIntoView({ behavior: 'smooth' });
  }

  document.querySelectorAll('.thumb-card').forEach((card) => {
    card.addEventListener('click', () => {
      const type = card.dataset.type;
      const tab = card.dataset.tab;
      const videoId = card.dataset.videoid;
      const playlist = card.dataset.playlist;

      if (type === 'video' && videoId) {
        play(tab, videoId);
      } else if (playlist) {
        window.open('https://www.youtube.com/playlist?list=' + playlist, '_blank');
      }
    });
  });
</script>

</MainLayout>
