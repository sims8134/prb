---

<MainLayout
  lang={lang}
  title={t.legal.title}
  description={t.legal.description}
  nav={buildNav(lang, t)}
  footer={buildFooter(lang, t)}
  active="legal"
  heroImage="/home/BackGroundHome.jpg"
>

<style>
.page-wrap {
  max-width: 800px;
  margin: 0 auto;
  padding: 30px 20px 60px;
}

.page-title {
  font-family: 'Oswald', sans-serif;
  font-size: 2.8rem;
  font-weight: 700;
  text-transform: uppercase;
  color: #f0ebe0;
  border-bottom: 3px solid #D62612;
  padding-bottom: 10px;
  margin-bottom: 8px;
}

.page-updated {
  font-size: 1.2rem;
  color: #555;
  margin-bottom: 24px;
  font-style: italic;
}

.legal-block {
  margin-bottom: 30px;
}

.legal-block h2 {
  font-family: 'Oswald', sans-serif;
  font-size: 1.9rem;
  font-weight: 700;
  text-transform: uppercase;
  color: #D62612;
  border-left: 4px solid #D62612;
  padding-left: 12px;
  margin-bottom: 12px;
}

.legal-block p {
  font-size: 1.45rem;
  color: #aaa;
  line-height: 1.85;
  margin-bottom: 8px;
}

.legal-block a {
  color: #D62612;
}

.legal-block a:hover {
  text-decoration: underline;
}

.notice-box {
  background: #242424;
  border-left: 4px solid #D62612;
  padding: 14px 18px;
  margin-bottom: 28px;
  font-size: 1.35rem;
  color: #888;
  font-style: italic;
  line-height: 1.7;
}

.company-box {
  background: #242424;
  border: 1px solid #333;
  padding: 14px 18px;
  margin: 8px 0;
  font-size: 1.4rem;
  color: #ccc;
  line-height: 1.7;
}
</style>

<div class="page-wrap">
  <h1 class="page-title">{copy.title}</h1>
  <p class="page-updated">{copy.updated}</p>

  <div class="notice-box">{copy.notice}</div>

  <div class="legal-block">
    <h2>{copy.publisher}</h2>
    <p>{copy.publisherText1}</p>
    <p>{copy.publisherText2}</p>
    <p>{copy.publisherText3}</p>
    <div class="company-box">{copy.publisherCompany}</div>
    <p>
      {copy.publisherContact}
      {" "}
      <a href="mailto:contact@peoplesrepublicofbulgaria.com">
        contact@peoplesrepublicofbulgaria.com
      </a>
    </p>
  </div>

  <div class="legal-block">
    <h2>{copy.hosting}</h2>
    <p>{copy.hostingText}</p>
  </div>

  <div class="legal-block">
    <h2>{copy.director}</h2>
    <p>{copy.directorText}</p>
  </div>

  <div class="legal-block">
    <h2>{copy.intellectual}</h2>
    <p>{copy.intellectualText}</p>
  </div>

  <div class="legal-block">
    <h2>{copy.cookies}</h2>
    <p>{copy.cookiesText1}</p>
    <p>{copy.cookiesText2}</p>
  </div>

  <div class="legal-block">
    <h2>{copy.purpose}</h2>
    <p>{copy.purposeText}</p>
  </div>

  <div class="legal-block">
    <h2>{copy.privacy}</h2>
    <p>
      {copy.privacyText}{" "}
      <a href={`/${lang}/privacy`}>{copy.privacyLink}</a>.
    </p>
  </div>

  <div class="legal-block">
    <h2>{copy.contact}</h2>
    <p>
      {copy.contactText}
      <br />
      <a href="mailto:contact@peoplesrepublicofbulgaria.com">
        contact@peoplesrepublicofbulgaria.com
      </a>
    </p>
  </div>
</div>

</MainLayout>
