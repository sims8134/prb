    publisherText1:
      "This site, accessible at https://www.peoplesrepublicofbulgaria.com, is published by:",
    publisherText2:
      "Simon Beltran, resident of Sofia, Bulgaria, French nationality, born on 06/17/1993.",
    publisherText3: "Contact:",
